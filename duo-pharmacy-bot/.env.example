# --- OpenAI ---
OPENAI_API_KEY=sk-REPLACE_ME
# Model routing (IDs are config, not code). Small/fast for intent + intake, mid for answers.
# Swap via env if your account lacks access (e.g. gpt-4o-mini / gpt-4o).
MODEL_INTENT=gpt-4.1-mini
MODEL_ANSWER=gpt-4.1

# --- CORS / environment ---
# Production origin for the widget. localhost origins are added automatically when DEV=true.
ALLOWED_ORIGIN=https://duoprimecarepharmacy.com
DEV=true

# --- Rate limiting (per IP and per session token, independently) ---
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_DAY=200

# --- Daily budget kill-switch (USD). In-memory for v1; resets on restart. ---
DAILY_BUDGET_USD=2.00

# --- Input validation ---
MAX_MESSAGE_CHARS=1000

# --- Pricing (USD per 1M tokens) used for the cost tally. Update if OpenAI pricing changes. ---
PRICE_INTENT_INPUT=0.40
PRICE_INTENT_OUTPUT=1.60
PRICE_ANSWER_INPUT=2.00
PRICE_ANSWER_OUTPUT=8.00
